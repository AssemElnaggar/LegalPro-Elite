# ============================================================================
# LegalPro Elite - متغيرات البيئة
# ============================================================================
# انسخ هذا الملف إلى .env واملأ القيم المناسبة لبيئتك
# cp .env.example .env
# ============================================================================

# ----------------------------------------------------------------------------
# قاعدة البيانات PostgreSQL
# ----------------------------------------------------------------------------
# رابط اتصال قاعدة البيانات
# الصيغة: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/legalpro_db

# ----------------------------------------------------------------------------
# إعدادات الخادم
# ----------------------------------------------------------------------------
# بيئة التشغيل: development, production
NODE_ENV=development

# منفذ الخادم (اختياري، الافتراضي 3000)
# PORT=3000

# ----------------------------------------------------------------------------
# إعدادات الأمان (اختياري)
# ----------------------------------------------------------------------------
# مفتاح تشفير الجلسات (يجب أن يكون 32 حرف عشوائي على الأقل)
# SESSION_SECRET=your-super-secret-session-key-minimum-32-characters

# مدة صلاحية الجلسة بالثواني (افتراضي: 30 يوم)
# SESSION_MAX_AGE=2592000

# ----------------------------------------------------------------------------
# إعدادات رفع الملفات
# ----------------------------------------------------------------------------
# الحد الأقصى لحجم الملف المرفوع بالبايت (افتراضي: 10MB)
# MAX_FILE_SIZE=10485760

# ----------------------------------------------------------------------------
# إعدادات البريد الإلكتروني (اختياري - للتنبيهات المستقبلية)
# ----------------------------------------------------------------------------
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-email-password
# SMTP_FROM=noreply@legalpro.local

# ----------------------------------------------------------------------------
# إعدادات إضافية (اختياري)
# ----------------------------------------------------------------------------
# مستوى السجلات: debug, info, warn, error
# LOG_LEVEL=info

# تمكين التصحيح
# DEBUG=false
